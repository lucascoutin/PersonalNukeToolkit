Group {
 name LN_QualityCheck
 knobChanged "\n\n#define variables\nntn = nuke.thisNode()\ncheck = nuke.thisNode().knob('checks').value()\nautochecks = nuke.thisNode().knob('autoChecks').value()\ngroup = nuke.thisGroup()\ntipo = nuke.thisNode().knob('tipo').value()\nntn.begin()\nswitch = nuke.toNode('_Switch').knob('which')\nntn.end()\n\nk = nuke.thisKnob()\n\nif k.name() == 'tipo':\n\n    if tipo == 'Essencial':\n\n        ntn.knob('CHK_lowExpo').setVisible(False)\n        ntn.knob('CHK_highExpo').setVisible(False)\n        ntn.knob('CHK_sat').setVisible(False)\n        ntn.knob('CHK_Diff').setVisible(False)\n        ntn.knob('CHK_BBox').setVisible(False)\n\n        views = \[\n        'Comp',\n        'Clipping',\n        'NaN-inf-zero_blacks',\n        'Grain',\n        'Mascara_para_a_Cor',\n        'Compare_Plate-Comp',\n        'Compare_Reference',\n        'Bordas_da_Comp'\n        ]\n\n        ntn.knob('checks').setValues(views)\n        ntn.knob('checks').setValue('Comp')\n\n\n    else:\n        ntn.knob('CHK_lowExpo').setVisible(True)\n        ntn.knob('CHK_highExpo').setVisible(True)\n        ntn.knob('CHK_sat').setVisible(True)\n        ntn.knob('CHK_Diff').setVisible(True)\n        ntn.knob('CHK_BBox').setVisible(True)\n\n        views = \[\n        'Comp',\n        'Difference',\n        'Clipping',\n        'Low_Exposure',\n        'High_Exposure',\n        'Saturation',\n        'NaN-inf-zero_blacks',\n        'Grain',\n        'BBox',\n        'Mascara_para_a_Cor',\n        'Compare_Plate-Comp',\n        'Compare_Reference',\n        'Bordas_da_Comp'\n        ]\n\n        ntn.knob('checks').setValues(views)\n\n\nif k.name() == 'checks':\n\n    #callbacks: pulldown choice changes Switch value\n\n    if check == 'Comp':\n        switch.setValue(0)\n        ntn.knob('gain_diff').setVisible(False)\n        ntn.knob('clip_maxValue').setVisible(False)\n        ntn.knob('gain_high').setVisible(False)\n        ntn.knob('gain_low').setVisible(False)\n        ntn.knob('illegal_Zero').setVisible(False)\n        ntn.knob('illegal_nan').setVisible(False)\n        ntn.knob('illegal_inf').setVisible(False)\n        ntn.knob('illegal_negative').setVisible(False)\n        ntn.knob('illegal_erode').setVisible(False)\n        ntn.knob('Wipe').setVisible(False)\n        ntn.knob('wipe_inv').setVisible(False)\n        ntn.knob('wipe_vertical').setVisible(False)\n        ntn.knob('wipe_buttonSwitch').setVisible(False)\n        ntn.knob('saturation').setVisible(False)\n\n    elif check == 'Difference':\n        switch.setValue(1)\n        ntn.knob('gain_diff').setVisible(True)\n        ntn.knob('clip_maxValue').setVisible(False)\n        ntn.knob('gain_high').setVisible(False)\n        ntn.knob('gain_low').setVisible(False)\n        ntn.knob('illegal_Zero').setVisible(False)\n        ntn.knob('illegal_nan').setVisible(False)\n        ntn.knob('illegal_inf').setVisible(False)\n        ntn.knob('illegal_negative').setVisible(False)\n        ntn.knob('illegal_erode').setVisible(False)\n        ntn.knob('Wipe').setVisible(False)\n        ntn.knob('wipe_inv').setVisible(False)\n        ntn.knob('wipe_vertical').setVisible(False)\n        ntn.knob('wipe_buttonSwitch').setVisible(False)\n        ntn.knob('saturation').setVisible(False)\n        if ntn.knob('autoChecks').value() == 1:\n            ntn.knob('CHK_Diff').setValue(True)\n\n    elif check == 'Clipping':\n        switch.setValue(2)\n        ntn.knob('gain_diff').setVisible(False)\n        ntn.knob('clip_maxValue').setVisible(True)\n        ntn.knob('gain_high').setVisible(False)\n        ntn.knob('gain_low').setVisible(False)\n        ntn.knob('saturation').setVisible(False)\n        ntn.knob('illegal_Zero').setVisible(False)\n        ntn.knob('illegal_nan').setVisible(False)\n        ntn.knob('illegal_inf').setVisible(False)\n        ntn.knob('illegal_negative').setVisible(False)\n        ntn.knob('illegal_erode').setVisible(False)\n        ntn.knob('Wipe').setVisible(False)\n        ntn.knob('wipe_inv').setVisible(False)\n        ntn.knob('wipe_vertical').setVisible(False)\n        ntn.knob('wipe_buttonSwitch').setVisible(False)\n        if ntn.knob('autoChecks').value() == 1:\n            ntn.knob('CHK_Clip').setValue(True)\n\n    elif check == 'High_Exposure':\n        switch.setValue(3)\n        ntn.knob('gain_diff').setVisible(False)\n        ntn.knob('clip_maxValue').setVisible(False)\n        ntn.knob('gain_high').setVisible(True)\n        ntn.knob('gain_low').setVisible(False)\n        ntn.knob('illegal_Zero').setVisible(False)\n        ntn.knob('illegal_nan').setVisible(False)\n        ntn.knob('illegal_inf').setVisible(False)\n        ntn.knob('illegal_negative').setVisible(False)\n        ntn.knob('illegal_erode').setVisible(False)\n        ntn.knob('Wipe').setVisible(False)\n        ntn.knob('wipe_inv').setVisible(False)\n        ntn.knob('wipe_vertical').setVisible(False)\n        ntn.knob('wipe_buttonSwitch').setVisible(False)\n        ntn.knob('saturation').setVisible(False)\n        if ntn.knob('autoChecks').value() == 1:\n            ntn.knob('CHK_highExpo').setValue(True)\n\n\n    elif check == 'Low_Exposure':\n        switch.setValue(4)\n        ntn.knob('gain_diff').setVisible(False)\n        ntn.knob('clip_maxValue').setVisible(False)\n        ntn.knob('gain_high').setVisible(False)\n        ntn.knob('gain_low').setVisible(True)\n        ntn.knob('saturation').setVisible(False)\n        ntn.knob('illegal_Zero').setVisible(False)\n        ntn.knob('illegal_nan').setVisible(False)\n        ntn.knob('illegal_inf').setVisible(False)\n        ntn.knob('illegal_negative').setVisible(False)\n        ntn.knob('illegal_erode').setVisible(False)\n        ntn.knob('Wipe').setVisible(False)\n        ntn.knob('wipe_inv').setVisible(False)\n        ntn.knob('wipe_vertical').setVisible(False)\n        ntn.knob('wipe_buttonSwitch').setVisible(False)\n        if ntn.knob('autoChecks').value() == 1:\n            ntn.knob('CHK_lowExpo').setValue(True)\n\n\n    elif check == 'Saturation':\n        switch.setValue(5)\n        ntn.knob('gain_diff').setVisible(False)\n        ntn.knob('clip_maxValue').setVisible(False)\n        ntn.knob('gain_high').setVisible(False)\n        ntn.knob('gain_low').setVisible(False)\n        ntn.knob('illegal_Zero').setVisible(False)\n        ntn.knob('illegal_nan').setVisible(False)\n        ntn.knob('illegal_inf').setVisible(False)\n        ntn.knob('illegal_negative').setVisible(False)\n        ntn.knob('illegal_erode').setVisible(False)\n        ntn.knob('Wipe').setVisible(False)\n        ntn.knob('wipe_inv').setVisible(False)\n        ntn.knob('wipe_vertical').setVisible(False)\n        ntn.knob('wipe_buttonSwitch').setVisible(False)\n        ntn.knob('saturation').setVisible(True)\n        if ntn.knob('autoChecks').value() == 1:\n            ntn.knob('CHK_sat').setValue(True)\n\n\n    elif check == 'NaN-inf-zero_blacks':\n        switch.setValue(6)\n        ntn.knob('gain_diff').setVisible(False)\n        ntn.knob('clip_maxValue').setVisible(False)\n        ntn.knob('gain_high').setVisible(False)\n        ntn.knob('gain_low').setVisible(False)\n        ntn.knob('saturation').setVisible(False)\n        ntn.knob('illegal_Zero').setVisible(True)\n        ntn.knob('illegal_nan').setVisible(True)\n        ntn.knob('illegal_inf').setVisible(True)\n        ntn.knob('illegal_negative').setVisible(True)\n        ntn.knob('illegal_erode').setVisible(True)\n        ntn.knob('Wipe').setVisible(False)\n        ntn.knob('wipe_inv').setVisible(False)\n        ntn.knob('wipe_vertical').setVisible(False)\n        ntn.knob('wipe_buttonSwitch').setVisible(False)\n        if ntn.knob('autoChecks').value() == 1:\n            ntn.knob('CHK_illegal').setValue(True)\n\n\n    elif check == 'Grain':\n        switch.setValue(7)\n        ntn.knob('gain_diff').setVisible(False)\n        ntn.knob('clip_maxValue').setVisible(False)\n        ntn.knob('gain_high').setVisible(False)\n        ntn.knob('gain_low').setVisible(False)\n        ntn.knob('saturation').setVisible(False)\n        ntn.knob('illegal_Zero').setVisible(False)\n        ntn.knob('illegal_nan').setVisible(False)\n        ntn.knob('illegal_inf').setVisible(False)\n        ntn.knob('illegal_negative').setVisible(False)\n        ntn.knob('illegal_erode').setVisible(False)\n        ntn.knob('Wipe').setVisible(True)\n        ntn.knob('wipe_inv').setVisible(True)\n        ntn.knob('wipe_vertical').setVisible(True)\n        ntn.knob('wipe_buttonSwitch').setVisible(True)\n        if ntn.knob('autoChecks').value() == 1:\n            ntn.knob('CHK_Grain').setValue(True)\n\n    elif check == 'BBox':\n        switch.setValue(8)\n        ntn.knob('gain_diff').setVisible(False)\n        ntn.knob('clip_maxValue').setVisible(False)\n        ntn.knob('gain_high').setVisible(False)\n        ntn.knob('gain_low').setVisible(False)\n        ntn.knob('saturation').setVisible(False)\n        ntn.knob('illegal_Zero').setVisible(False)\n        ntn.knob('illegal_nan').setVisible(False)\n        ntn.knob('illegal_inf').setVisible(False)\n        ntn.knob('illegal_negative').setVisible(False)\n        ntn.knob('illegal_erode').setVisible(False)\n        ntn.knob('Wipe').setVisible(False)\n        ntn.knob('wipe_inv').setVisible(False)\n        ntn.knob('wipe_vertical').setVisible(False)\n\n        ntn.knob('wipe_buttonSwitch').setVisible(False)\n        if ntn.knob('autoChecks').value() == 1:\n            ntn.knob('CHK_BBox').setValue(True)\n\n\n    elif check == 'Mascara_para_a_Cor':\n        switch.setValue(11)\n        ntn.knob('gain_diff').setVisible(False)\n        ntn.knob('clip_maxValue').setVisible(False)\n        ntn.knob('gain_high').setVisible(False)\n        ntn.knob('gain_low').setVisible(False)\n        ntn.knob('saturation').setVisible(False)\n        ntn.knob('illegal_Zero').setVisible(False)\n        ntn.knob('illegal_nan').setVisible(False)\n        ntn.knob('illegal_inf').setVisible(False)\n        ntn.knob('illegal_negative').setVisible(False)\n        ntn.knob('illegal_erode').setVisible(False)\n        ntn.knob('Wipe').setVisible(False)\n        ntn.knob('wipe_inv').setVisible(False)\n        ntn.knob('wipe_vertical').setVisible(False)\n        ntn.knob('wipe_buttonSwitch').setVisible(False)\n        if ntn.knob('autoChecks').value() == 1:\n            ntn.knob('CHK_DImattes').setValue(True)\n\n    elif check == 'Compare_Plate-Comp':\n        switch.setValue(9)\n        ntn.knob('gain_diff').setVisible(False)\n        ntn.knob('clip_maxValue').setVisible(False)\n        ntn.knob('gain_high').setVisible(False)\n        ntn.knob('gain_low').setVisible(False)\n        ntn.knob('saturation').setVisible(False)\n        ntn.knob('illegal_Zero').setVisible(False)\n        ntn.knob('illegal_nan').setVisible(False)\n        ntn.knob('illegal_inf').setVisible(False)\n        ntn.knob('illegal_negative').setVisible(False)\n        ntn.knob('illegal_erode').setVisible(False)\n        ntn.knob('Wipe').setVisible(True)\n        ntn.knob('wipe_inv').setVisible(True)\n        ntn.knob('wipe_vertical').setVisible(True)\n        ntn.knob('wipe_buttonSwitch').setVisible(True)\n        if ntn.knob('autoChecks').value() == 1:\n            ntn.knob('CHK_plateComp').setValue(True)\n\n    elif check == 'Compare_Reference':\n        switch.setValue(10)\n        ntn.knob('gain_diff').setVisible(False)\n        ntn.knob('clip_maxValue').setVisible(False)\n        ntn.knob('gain_high').setVisible(False)\n        ntn.knob('gain_low').setVisible(False)\n        ntn.knob('saturation').setVisible(False)\n        ntn.knob('illegal_Zero').setVisible(False)\n        ntn.knob('illegal_nan').setVisible(False)\n        ntn.knob('illegal_inf').setVisible(False)\n        ntn.knob('illegal_negative').setVisible(False)\n        ntn.knob('illegal_erode').setVisible(False)\n        ntn.knob('Wipe').setVisible(True)\n        ntn.knob('wipe_inv').setVisible(True)\n        ntn.knob('wipe_vertical').setVisible(True)\n        ntn.knob('wipe_buttonSwitch').setVisible(True)\n        if ntn.knob('autoChecks').value() == 1:\n            ntn.knob('CHK_ref').setValue(True)\n\n    elif check == 'Bordas_da_Comp':\n        switch.setValue(13)\n        ntn.knob('gain_diff').setVisible(False)\n        ntn.knob('clip_maxValue').setVisible(False)\n        ntn.knob('gain_high').setVisible(False)\n        ntn.knob('gain_low').setVisible(False)\n        ntn.knob('saturation').setVisible(False)\n        ntn.knob('illegal_Zero').setVisible(False)\n        ntn.knob('illegal_nan').setVisible(False)\n        ntn.knob('illegal_inf').setVisible(False)\n        ntn.knob('illegal_negative').setVisible(False)\n        ntn.knob('illegal_erode').setVisible(False)\n        ntn.knob('Wipe').setVisible(False)\n        ntn.knob('wipe_inv').setVisible(False)\n        ntn.knob('wipe_vertical').setVisible(False)\n        ntn.knob('wipe_buttonSwitch').setVisible(False)\n        if ntn.knob('autoChecks').value() == 1:\n            ntn.knob('CHK_streched').setValue(True)\n\n\n\ndef changeNodeColor():\n\n    if tipo == 'Essencial':\n        \n        checkKnobs = \[\n        ntn.knob('CHK_Clip').value(),\n        ntn.knob('CHK_illegal').value(),\n        ntn.knob('CHK_Grain').value(),\n        ntn.knob('CHK_plateComp').value(),\n        ntn.knob('CHK_ref').value(),\n        ntn.knob('CHK_DImattes').value(),\n        ntn.knob('CHK_notes').value(),\n        ntn.knob('CHK_streched').value()\n        ]\n\n\n    else:\n\n        checkKnobs = \[\n        ntn.knob('CHK_Diff').value(),\n        ntn.knob('CHK_Clip').value(),\n        ntn.knob('CHK_highExpo').value(),\n        ntn.knob('CHK_lowExpo').value(),\n        ntn.knob('CHK_sat').value(),\n        ntn.knob('CHK_illegal').value(),\n        ntn.knob('CHK_Grain').value(),\n        ntn.knob('CHK_BBox').value(),\n        ntn.knob('CHK_plateComp').value(),\n        ntn.knob('CHK_ref').value(),\n        ntn.knob('CHK_DImattes').value(),\n        ntn.knob('CHK_notes').value(),\n        ntn.knob('CHK_streched').value()\n        ]\n\n    if all(v == True for v in checkKnobs):\n        ntn\['tile_color'].setValue(14024959)\n        ntn\['label'].setValue('COMPLETO')\n    else:\n        ntn\['tile_color'].setValue(3758096639)\n        ntn\['label'].setValue('INCOMPLETO')\n\nchangeNodeColor()\n"
